<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Dark circular background -->
    <path
        android:pathData="M54,54 m-54,0 a54,54 0 1,0 108,0 a54,54 0 1,0 -108,0"
        android:fillColor="#16213E"/>

    <!--
        Three 120° arc segments on a ring of radius 42, centred at 54,54.
        Key points (on the circle):
          Top   270°: (54, 12)
          Right  30°: (91, 75)
          Left  150°: (17, 75)
        Each arc uses A42,42 0 0,1 (small arc, clockwise sweep).
    -->

    <!-- Green arc: top → right  (W' healthy) -->
    <path
        android:pathData="M54,12 A42,42 0 0,1 91,75"
        android:fillColor="#00000000"
        android:strokeColor="#109C77"
        android:strokeWidth="12"
        android:strokeLineCap="round"/>

    <!-- Orange arc: right → left, through bottom  (W' getting low) -->
    <path
        android:pathData="M91,75 A42,42 0 0,1 17,75"
        android:fillColor="#00000000"
        android:strokeColor="#E5683C"
        android:strokeWidth="12"
        android:strokeLineCap="round"/>

    <!-- Purple arc: left → top  (W' critical) -->
    <path
        android:pathData="M17,75 A42,42 0 0,1 54,12"
        android:fillColor="#00000000"
        android:strokeColor="#AF26A0"
        android:strokeWidth="12"
        android:strokeLineCap="round"/>

    <!-- Lightning bolt — power/W' symbol, white, centred in ring -->
    <path
        android:pathData="M62,27 L44,56 L55,56 L45,81 L66,52 L54,52 Z"
        android:fillColor="#FFFFFF"/>

</vector>
